# Copy this file to .env and adjust as needed. The defaults work out of the box
# with docker compose, so a .env file is optional.

# Connection string the app and ETL use to reach Postgres.
DATABASE_URL=postgresql://opspulse:opspulse@db:5432/opspulse

# Optional. Leave blank to run the AI Daily Insights panel in demo mode, which
# returns a committed sample summary so the whole app runs with no key.
# Set a real key to have Claude write the weekly summary live.
ANTHROPIC_API_KEY=
